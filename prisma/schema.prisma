// ERP Curso de Redação — gestão acadêmica, financeira e operacional
// PostgreSQL (Neon / produção)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PerfilUsuario {
  ADMIN
  PROFESSOR
  ALUNO
}

enum SituacaoAluno {
  ATIVO
  INATIVO
  DEVENDO
}

enum ClasseTurma {
  ENSINO_FUNDAMENTAL
  ENSINO_MEDIO
}

enum TipoPlano {
  MENSAL
  BIMESTRAL
  TRIMESTRAL
  BOLSA_50
  BOLSA_100
}

enum StatusParcela {
  PENDENTE
  PAGO
  ATRASADO
  ISENTO
}

enum PrioridadeAviso {
  BAIXA
  MEDIA
  ALTA
}

/// Contador para códigos R0001, Prof001, MD01
model SequenciaCodigo {
  entidade String @id
  proximo  Int    @default(1)
}

model ConfiguracaoSistema {
  id                        String   @id @default("singleton")
  senhaPadraoAlunoHash      String   @default("")
  primeiroAcessoSenhaPlano  String   @default("123456")
  atualizadoEm              DateTime @updatedAt
}

model Curso {
  id        String   @id @default(cuid())
  codigo    String   @unique
  nome      String
  ativo     Boolean  @default(true)
  criadoEm  DateTime @default(now())
  turmas    Turma[]
  matriculas Matricula[]
  avisos    AvisoSistema[]
}

model Turma {
  id          String   @id @default(cuid())
  codigo      String
  nome        String
  cursoId     String
  curso       Curso    @relation(fields: [cursoId], references: [id], onDelete: Cascade)
  horaInicio  String?
  horaFim     String?
  /// 0 = domingo … 6 = sábado
  diaSemana   Int?
  classe      ClasseTurma @default(ENSINO_MEDIO)
  capacidade  Int      @default(35)
  ativa       Boolean  @default(true)
  criadoEm    DateTime @default(now())
  matriculas  Matricula[]
  professores ProfessorTurma[]
  avisos      AvisoSistema[]
  aulasAgendadas AulaAgendada[]

  @@unique([cursoId, codigo])
}

model Usuario {
  id             String        @id @default(cuid())
  email          String        @unique
  nome           String
  senhaHash      String
  perfil         PerfilUsuario @default(ALUNO)
  ativo          Boolean       @default(true)
  acessoExpiraEm DateTime?
  criadoEm       DateTime      @default(now())
  atualizadoEm   DateTime      @updatedAt
  aluno          Aluno?
  professor      Professor?
}

model Professor {
  id             String   @id @default(cuid())
  codigoPublico  String   @unique
  nome           String
  materia        String
  usuarioId      String?  @unique
  usuario        Usuario? @relation(fields: [usuarioId], references: [id])
  criadoEm       DateTime @default(now())
  turmas         ProfessorTurma[]
  aulasAgendadas AulaAgendada[]
}

model ProfessorTurma {
  professorId String
  turmaId     String
  professor   Professor @relation(fields: [professorId], references: [id], onDelete: Cascade)
  turma       Turma     @relation(fields: [turmaId], references: [id], onDelete: Cascade)

  @@id([professorId, turmaId])
}

/// Até 2 matrículas por aluno (curso/turma)
model Matricula {
  id        String   @id @default(cuid())
  alunoId   String
  aluno     Aluno    @relation(fields: [alunoId], references: [id], onDelete: Cascade)
  cursoId   String
  curso     Curso    @relation(fields: [cursoId], references: [id], onDelete: Cascade)
  turmaId   String
  turma     Turma    @relation(fields: [turmaId], references: [id], onDelete: Cascade)
  ordem     Int

  @@unique([alunoId, ordem])
  @@unique([alunoId, turmaId])
}

model Aluno {
  id        String @id @default(cuid())
  codigoPublico String @unique
  usuarioId String? @unique
  usuario   Usuario? @relation(fields: [usuarioId], references: [id])

  nomeCompleto String
  emailContato String
  telefone     String
  responsavel  String?

  situacao SituacaoAluno @default(ATIVO)

  tipoPlano     TipoPlano @default(MENSAL)
  diaPagamento  Int?
  mesesCobranca Int[]     @default([])

  acessoSofiaEmail     String?
  acessoSofiaSenhaRef  String?
  acessoCoredacaoEmail String?
  acessoCoredacaoSenhaRef String?

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  matriculas Matricula[]
  presencas  PresencaEncontro[]
  materiais  MaterialEncontro[]
  parcelas   ParcelaModulo[]
  entregasRedacao EntregaRedacao[]
  reposicoes ReposicaoRegistro[]
}

model Semestre {
  id      String        @id @default(cuid())
  nome    String
  ativo   Boolean       @default(true)
  modulos ModuloCurso[]
}

model ModuloCurso {
  id             String    @id @default(cuid())
  codigoPublico  String?   @unique
  semestreId     String
  semestre       Semestre  @relation(fields: [semestreId], references: [id], onDelete: Cascade)
  numero         Int
  titulo         String?
  mesReferencia  Int?
  anoReferencia  Int?
  encontros      Encontro[]
  aulasAgendadas AulaAgendada[]
}

model Encontro {
  id        String      @id @default(cuid())
  moduloId  String
  modulo    ModuloCurso @relation(fields: [moduloId], references: [id], onDelete: Cascade)
  ordem     Int
  rotulo    String

  presencas PresencaEncontro[]
  materiais MaterialEncontro[]
}

model PresencaEncontro {
  id              String   @id @default(cuid())
  alunoId         String
  aluno           Aluno    @relation(fields: [alunoId], references: [id], onDelete: Cascade)
  encontroId      String
  encontro        Encontro @relation(fields: [encontroId], references: [id], onDelete: Cascade)
  dataAula        DateTime
  presente        Boolean  @default(false)
  reposicao       Boolean  @default(false)
  entregouRedacao String?
  assinaturaRef   String?

  @@unique([alunoId, encontroId])
}

model MaterialEncontro {
  id           String   @id @default(cuid())
  alunoId      String
  aluno        Aluno    @relation(fields: [alunoId], references: [id], onDelete: Cascade)
  encontroId   String
  encontro     Encontro @relation(fields: [encontroId], references: [id], onDelete: Cascade)
  proposta     Boolean  @default(false)
  materialAula Boolean  @default(false)
  pasta        Boolean  @default(false)

  @@unique([alunoId, encontroId])
}

model ParcelaModulo {
  id             String        @id @default(cuid())
  alunoId        String
  aluno          Aluno         @relation(fields: [alunoId], references: [id], onDelete: Cascade)
  moduloNumero   Int
  status         StatusParcela @default(PENDENTE)
  valorBase      Decimal?      @db.Decimal(12, 2)
  desconto       Decimal?      @db.Decimal(12, 2)
  valorFinal     Decimal?      @db.Decimal(12, 2)
  comprovanteUrl String?
  assinaturaRef  String?
  pagoEm         DateTime?

  @@unique([alunoId, moduloNumero])
}

model EntregaRedacao {
  id              String   @id @default(cuid())
  alunoId         String
  aluno           Aluno    @relation(fields: [alunoId], references: [id], onDelete: Cascade)
  quantidade      Int      @default(1)
  viaSecretaria   Boolean  @default(false)
  observacao      String?
  dataRegistro    DateTime @default(now())
}

model ReposicaoRegistro {
  id               String   @id @default(cuid())
  alunoId          String
  aluno            Aluno    @relation(fields: [alunoId], references: [id], onDelete: Cascade)
  moduloRef        String?
  descricaoFalta   String?
  dataReposicao    DateTime
  criadoEm         DateTime @default(now())
}

model AvisoSistema {
  id        String   @id @default(cuid())
  titulo    String
  mensagem  String
  /// Ordenação interna (maior = destaque)
  prioridade Int     @default(0)
  prioridadeNivel PrioridadeAviso @default(MEDIA)
  ativo     Boolean  @default(true)
  criadoEm  DateTime @default(now())

  paraTodasTurmas Boolean @default(true)
  enviarAlunos    Boolean @default(true)
  enviarProfessores Boolean @default(false)

  cursoId String?
  curso   Curso?  @relation(fields: [cursoId], references: [id], onDelete: SetNull)
  turmaId String?
  turma   Turma?  @relation(fields: [turmaId], references: [id], onDelete: SetNull)
}

/// Aulas e eventos pontuais no calendário (complementa a grade recorrente da turma)
model AulaAgendada {
  id        String   @id @default(cuid())
  data      DateTime
  titulo    String?
  observacao String?

  turmaId     String
  turma       Turma     @relation(fields: [turmaId], references: [id], onDelete: Cascade)
  moduloId    String?
  modulo      ModuloCurso? @relation(fields: [moduloId], references: [id], onDelete: SetNull)
  professorId String?
  professor   Professor? @relation(fields: [professorId], references: [id], onDelete: SetNull)

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt
}
