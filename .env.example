# Copie para .env e ajuste (Neon: Dashboard → Connection string → URI)
# Desenvolvimento local com SQLite não é mais o padrão — use PostgreSQL (Neon free tier).
DATABASE_URL="postgresql://USER:PASSWORD@HOST.region.aws.neon.tech/neondb?sslmode=require"

# WhatsApp (links na tela de login) — apenas dígitos, com DDI 55
# NEXT_PUBLIC_WHATSAPP_PHONE=5562981899570

# Sessão JWT (login). Em produção use uma string longa e aleatória (ex.: openssl rand -base64 32)
# AUTH_SECRET=

